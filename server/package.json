{
  "name": "kaleido-server",
  "version": "1.0.0",
  "description": "Backend server for Kaleido NFT platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "deploy": "bash deploy.sh",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js --env production",
    "pm2:logs": "pm2 logs kaleido-server",
    "pm2:monitor": "pm2 monit kaleido-server"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.14.1",
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "pm2": "^5.3.1",
    "qrcode": "^1.5.4",
    "siwe": "^2.1.4",
    "speakeasy": "^2.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mysql2": "types/mysql2",
    "@types/node": "^20.10.4",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  }
}
